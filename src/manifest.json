{
  "manifest_version": 3,
  "name": "Mattermost Deck",
  "version": "0.1.0",
  "description": "Adds a TweetDeck-style right rail to Mattermost Web.",
  "permissions": ["storage"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["http://*/*", "https://*/*"]
}
