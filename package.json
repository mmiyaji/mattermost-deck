{
  "name": "mattermost-deck",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "capture:readme": "node ./scripts/capture-readme.mjs",
    "dev": "node ./scripts/build.mjs --watch",
    "check": "tsc --noEmit",
    "open:mattermost": "node ./scripts/open-mattermost.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "mm95:start": "node ./scripts/mm95-start.mjs",
    "mm95:stop": "node ./scripts/mm95-start.mjs --stop",
    "test:theme": "MATTERMOST_BASE_URL=http://127.0.0.1:8066 MM95_STATE_FILE=e2e/mm95-state.json playwright test e2e/theme-compat.spec.ts --headed"
  },
  "dependencies": {
    "i18next": "^26.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.1.39",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "^0.25.11",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
